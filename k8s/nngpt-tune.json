{
  "apiVersion": "batch/v1",
  "kind": "Job",
  "metadata": {
    "name": "nngpt-train-102"
  },
  "spec": {
    "parallelism": 1,
    "ttlSecondsAfterFinished": 86400,
    "template": {
      "spec": {
        "containers": [{
          "args": ["python3 -u /a/mm/run.py ab.gpt.TuneNNGen --llm_conf ds_coder_7b_olympic.json --num_train_epochs 1 --test_nn 20 --learning_rate 5e-6"],
          "securityContext": {
            "allowPrivilegeEscalation": false,
            "runAsUser": "<user id>",
            "runAsGroup": 1376
          },
          "volumeMounts": [{
            "mountPath": "/dev/shm",
            "name": "shm"
          }, {
            "mountPath": "/a/mm",
            "name": "v0"
          }, {
            "mountPath": "/a/mm/data",
            "name": "v1"
          }],
          "name": "ml",
          "command": ["/bin/bash", "-c"],
          "imagePullPolicy": "Always",
          "image": "ws.ab/shared/ai-linux-nngpt:v1",
          "resources": {
            "requests": {
              "nvidia.com/gpu": 1,
              "cpu": 8,
              "memory": "30Gi"
            },
            "limits": {
              "nvidia.com/gpu": 1,
              "cpu": 64,
              "memory": "120Gi"
            }
          }
        }],
        "restartPolicy": "Never",
        "volumes": [{
          "name": "shm",
          "emptyDir": {
            "medium": "Memory",
            "sizeLimit": "16Gi"
          }
        }, {
          "name": "v0",
          "hostPath": {
            "path": "/shared/ssd/home/<user name>/nngpt/nn-gpt",
            "type": "DirectoryOrCreate"
          }
        }, {
          "name": "v1",
          "hostPath": {
            "path": "/shared/local/data/a-group-automl/data",
            "type": "DirectoryOrCreate"
          }
        }]
      }
    }
  }
}

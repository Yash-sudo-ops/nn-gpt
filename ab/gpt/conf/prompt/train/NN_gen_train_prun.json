{
    "efficiency_estimation": {
        "task": "img-classification",
        "input_list": [
            {
                "para": "accuracy",
                "value": "accuracy"
            },
            {
                "para": "duration",
                "value": "duration"
            },
            {
                "para": "model_name",
                "value": "model_name"
            }
        ],
        "prompt": [
            "For the computer vision model {model_name}, given its accuracy and inference time, estimate its inference efficiency.",
            "Accuracy: {accuracy}",
            "Inference time: {duration}s"
        ],
        "output": [
            "The inference efficiency for {model_name} is << accuracy / duration >>."
        ]
    },
    "model_recommendation_by_efficiency": {
        "task": "img-classification",
        "input_list": [
            {
                "para": "accuracy",
                "value": "accuracy"
            },
            {
                "para": "duration",
                "value": "duration"
            },
            {
                "para": "model_name",
                "value": "model_name"
            }
        ],
        "prompt": [
            "Please provide a computer vision model which gives us an accuracy around {accuracy} and an inference efficiency around << accuracy / duration >>."
        ],
        "output": [
            "The model {model_name} fits this criteria."
        ]
    }
}